# Application
FLASK_ENV=development
SECRET_KEY=change-me-in-production
DATABASE_URL=sqlite:////Users/amirhoseinabbasi/Desktop/jornal-main/backend/data/journal.db

# MT4 Bridge
# demo  = sample account data (no terminal required)
# bridge = read JSON files written by TradeJournalBridge.mq4
MT4_ADAPTER=demo
MT4_BRIDGE_PATH=./data/mt4_bridge
MT4_BRIDGE_STALE_SECONDS=120

# Sync
SYNC_INTERVAL_SECONDS=60